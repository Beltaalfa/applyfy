# =============================================================================
# Hub → Applyfy (fluxo B apenas: cookie JWT HS256, como em hub/docs/INTEGRACAO-APPLYFY.md)
# Cole no .env do servidor Applyfy. O segredo DEVE ser o mesmo que HUB_APPLYFY_JWT_SECRET no Hub.
# Gera FLASK_SECRET_KEY:  python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

APPLYFY_AUTH_ENABLED=1

FLASK_SECRET_KEY=COLE_AQUI_UM_HEX_64_CARACTERES_OU_MAIS

SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

HUB_LOGIN_URL=https://hub.northempresarial.com/login
# Se o Hub não tiver /logout, use o login até existir rota dedicada:
HUB_LOGOUT_URL=https://hub.northempresarial.com/login

# URL pública do painel (callback após login no Hub) e proxy atrás do Nginx:
APPLYFY_PUBLIC_URL=https://applyfy.northempresarial.com
APPLYFY_TRUST_PROXY=1

# Opcional: allowlist — ids no JWT (client_id com HUB_APPLYFY_JWT_INCLUDE_CLIENT_ID=1 no Hub, ou project_id/tenant_id)
# APPLYFY_HUB_ALLOWED_PROJECT_IDS=id_empresa_applyfy

# Igual a HUB_APPLYFY_COOKIE_NAME no Hub (default em ambos: access_token)
HUB_JWT_COOKIE_NAME=access_token

# Igual a HUB_APPLYFY_JWT_SECRET no Hub (pode usar HUB_APPLYFY_JWT_SECRET aqui em vez desta linha)
HUB_JWT_SECRET=O_MESMO_VALOR_QUE_HUB_APPLYFY_JWT_SECRET_NO_HUB
# HUB_APPLYFY_JWT_SECRET=alternativa_ao_HUB_JWT_SECRET_mesmo_valor

# HS256 apenas com o Hub atual. Não configure HUB_JWKS_URL salvo migração futura para RS256.
# HUB_JWT_ALGORITHMS=HS256

# Não usado com o Hub atual (sem authorization_code):
# HUB_TOKEN_URL=...
# HUB_CLIENT_ID=...
# HUB_CLIENT_SECRET=...
# HUB_REDIRECT_URI=...

# =============================================================================
# Desligar auth Hub: APPLYFY_AUTH_ENABLED=0 ou remover este bloco.
# =============================================================================
