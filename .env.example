# Applyfy Painel – variáveis de ambiente (copie para .env e preencha)
# NUNCA commite o arquivo .env com valores reais.

# Login Applyfy (obrigatório para login automático)
# Se a senha tiver $ # ( ) etc., use ASPAS SIMPLES em volta do valor
APPLYFY_USER=seu_email@exemplo.com
APPLYFY_PASSWORD='sua_senha'
APPLYFY_TOTP_SECRET=SUA_CHAVE_BASE32_DO_2FA

# Dados: diretório onde ficam sessão, CSV e XLSX (opcional; default: ./data)
# APPLYFY_DATA_DIR=/var/www/applyfy/data

# Export de saldos: retomar checkpoint (export_checkpoint.json) até N dias após o run_at gravado.
# Default 1 = hoje e ontem; 0 = só no mesmo dia; 7 = até uma semana.
# APPLYFY_EXPORT_CHECKPOINT_MAX_AGE_DAYS=1

# PostgreSQL — obrigatório para extrato OFX/CSV e lançamentos no Financeiro
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/applyfy
# Ou variáveis separadas:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=applyfy
# PG_PASSWORD=senha
# PG_DATABASE=applyfy

# App (opcional)
# FLASK_DEBUG=0
# HEADLESS=1
# Upload de extratos (MB); default 35
# APPLYFY_MAX_UPLOAD_MB=35

# API Admin ApplyFy (webhooks + taxas dos produtores)
# Obtenha no painel: Integrações > API / Webhooks
# APPLYFY_PUBLIC_KEY=sua_public_key
# APPLYFY_SECRET_KEY=sua_secret_key
# APPLYFY_WEBHOOK_TOKEN=token_gerado_ao_criar_webhook

# Meta de vendas líquidas (painel /meta e notificações WAHA; default 10000)
# APPLYFY_META_VENDAS_LIQUIDAS=10000

# WAHA (WhatsApp HTTP API) — notificações após export e alertas opcionais
# WAHA_NOTIFY_ENABLED=1
# WAHA_BASE_URL=https://seu-waha.exemplo.com
# WAHA_API_KEY=opcional_se_o_servidor_exigir
# WAHA_SESSION=default
# Pausa entre destinos (WEBJS/Puppeteer falha menos com 1–2 s): default 1.2
# WAHA_SEND_DELAY_SEC=1.2
# Um destino:
# WAHA_NOTIFY_CHAT_ID=5511999999999@c.us
# Vários destinos (mesma mensagem para todos), separados por vírgula:
# WAHA_NOTIFY_CHAT_IDS=5511999999999@c.us,5521988887777@c.us,120363...@g.us
# Se aparecer HTTP 403 "1010" (Cloudflare), o waha_client já envia User-Agent de browser; pode forçar:
# WAHA_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/131.0.0.0 Safari/537.36
# WAHA_ALERT_ON_FAILURE=1
# WAHA_ALERT_WEBHOOK_SILENCE=1

# Limites para painel /integracoes (horas)
# APPLYFY_EXPORT_STALE_HOURS=48
# APPLYFY_WEBHOOK_SILENCE_HOURS=24

# Token para rotas admin (teste WAHA, listar/retry DLQ). Header: X-Applyfy-Admin-Token
# APPLYFY_ADMIN_TOKEN=gere_um_segredo_longo

# --- Hub (login central; fluxo B: cookie JWT HS256 — ver docs/HUB_INTEGRACAO_APPLYFY.md) ---
# Bloco comentado pronto para colar: docs/env-bloco-hub-exemplo.env
# Checklist deploy no servidor Hub: docs/HUB_OPERADORES_CHECKLIST.md
# APPLYFY_AUTH_ENABLED=1
# Com auth Hub ligada, FLASK_SECRET_KEY é obrigatório (valor fixo); sem isto a app não arranca.
# FLASK_SECRET_KEY=gere_um_segredo_longo_fixo
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SAMESITE=Lax
# URL interna do Hub (Next.js) para proxy de API admin (permissões por tela em /permissoes). Default: http://127.0.0.1:3007
# HUB_INTERNAL_URL=http://127.0.0.1:3007
# Hostname público do Hub (Host / X-Forwarded-Host no proxy; NextAuth valida cookies com este host). Default: derivado de HUB_LOGIN_URL ou hub.northempresarial.com
# HUB_INTERNAL_HOST=hub.northempresarial.com
# HUB_LOGIN_URL=https://hub.northempresarial.com/login
# HUB_LOGOUT_URL=https://hub.northempresarial.com/logout
# (/logout no Hub = signOut NextAuth; só /login deixa a sessão Hub activa.)
# Se o Hub não expuser /logout, use a URL de login (ver docs/HUB_INTEGRACAO_APPLYFY.md).
# HUB_JWT_COOKIE_NAME=access_token
# Mesmo segredo que HUB_APPLYFY_JWT_SECRET no Hub (ou use HUB_APPLYFY_JWT_SECRET aqui):
# HUB_JWT_SECRET=...
# HUB_APPLYFY_JWT_SECRET=...
# RS256/JWKS e HUB_TOKEN_URL: opcional; Hub atual usa só HS256 + cookie (sem authorization_code).
# Claims: sub, permissions, scope, hub_role (admin|client) — doc completa em docs/HUB_INTEGRACAO_APPLYFY.md
# URL pública do painel (callback após login no Hub) e proxy atrás do Nginx:
# APPLYFY_PUBLIC_URL=https://applyfy.northempresarial.com
# APPLYFY_TRUST_PROXY=1
# Permissões .env em produção: sudo chown root:www-data .env && sudo chmod 640 .env
# Opcional: allowlist no JWT (project_id, tenant_id ou client_id). No Hub: HUB_APPLYFY_JWT_INCLUDE_CLIENT_ID=1 para enviar client_id.
# APPLYFY_HUB_ALLOWED_PROJECT_IDS=id1,id2
# Parâmetro de retorno no login do Hub (NextAuth costuma usar callbackUrl):
# HUB_LOGIN_RETURN_PARAM=callbackUrl
# HUB_LOGIN_APPEND_NEXT=1
