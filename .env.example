# Applyfy Painel – variáveis de ambiente (copie para .env e preencha)
# NUNCA commite o arquivo .env com valores reais.

# Login Applyfy (obrigatório para login automático)
# Se a senha tiver $ # ( ) etc., use ASPAS SIMPLES em volta do valor
APPLYFY_USER=seu_email@exemplo.com
APPLYFY_PASSWORD='sua_senha'
APPLYFY_TOTP_SECRET=SUA_CHAVE_BASE32_DO_2FA

# Dados: diretório onde ficam sessão, CSV e XLSX (opcional; default: ./data)
# APPLYFY_DATA_DIR=/var/www/applyfy/data

# PostgreSQL (opcional; se não definir, o painel usa apenas os arquivos CSV/XLSX em data/)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/applyfy
# Ou variáveis separadas:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=applyfy
# PG_PASSWORD=senha
# PG_DATABASE=applyfy

# App (opcional)
# FLASK_DEBUG=0
# HEADLESS=1

# API Admin ApplyFy (webhooks + taxas dos produtores)
# Obtenha no painel: Integrações > API / Webhooks
# APPLYFY_PUBLIC_KEY=sua_public_key
# APPLYFY_SECRET_KEY=sua_secret_key
# APPLYFY_WEBHOOK_TOKEN=token_gerado_ao_criar_webhook

# Meta de vendas líquidas (painel /meta e notificações WAHA; default 10000)
# APPLYFY_META_VENDAS_LIQUIDAS=10000

# WAHA (WhatsApp HTTP API) — notificações após export e alertas opcionais
# WAHA_NOTIFY_ENABLED=1
# WAHA_BASE_URL=https://seu-waha.exemplo.com
# WAHA_API_KEY=opcional_se_o_servidor_exigir
# WAHA_SESSION=default
# Pausa entre destinos (WEBJS/Puppeteer falha menos com 1–2 s): default 1.2
# WAHA_SEND_DELAY_SEC=1.2
# Um destino:
# WAHA_NOTIFY_CHAT_ID=5511999999999@c.us
# Vários destinos (mesma mensagem para todos), separados por vírgula:
# WAHA_NOTIFY_CHAT_IDS=5511999999999@c.us,5521988887777@c.us,120363...@g.us
# Se aparecer HTTP 403 "1010" (Cloudflare), o waha_client já envia User-Agent de browser; pode forçar:
# WAHA_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/131.0.0.0 Safari/537.36
# WAHA_ALERT_ON_FAILURE=1
# WAHA_ALERT_WEBHOOK_SILENCE=1

# Limites para painel /integracoes (horas)
# APPLYFY_EXPORT_STALE_HOURS=48
# APPLYFY_WEBHOOK_SILENCE_HOURS=24

# Token para rotas admin (teste WAHA, listar/retry DLQ). Header: X-Applyfy-Admin-Token
# APPLYFY_ADMIN_TOKEN=gere_um_segredo_longo
